{
  "name": "@bluestep-systems/b6p-cli",
  "version": "0.4.0",
  "description": "Command-line interface for BlueStep B6P script management",
  "license": "MIT",
  "homepage": "https://github.com/Bluestep-Systems/b6p-cli#readme",
  "bugs": {
    "url": "https://github.com/Bluestep-Systems/b6p-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bluestep-Systems/b6p-cli.git"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "b6p": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "compile": "node esbuild.js --production",
    "build:sea": "node scripts/build-sea.mjs",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "node esbuild.test.js",
    "clean": "rm -rf dist dist-test",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run clean && npm run lint && npm run check-types && npm run compile"
  },
  "devDependencies": {
    "@bluestep-systems/b6p-core": "^0.4.0",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "commander": "^14.0.3",
    "esbuild": "^0.27.4",
    "eslint": "^9.34.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.2"
  }
}
